{
  "name": "@inkress/storefront-sdk",
  "version": "1.1.0",
  "description": "Official Inkress Storefront SDK for JavaScript/TypeScript — everything you need to build a storefront on Inkress, in the browser or Node.js.",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "browser": "dist/index.browser.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:clean": "npm run clean && npm run build",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build",
    "prepublishOnly": "npm run test && npm run type-check && npm run build:clean"
  },
  "keywords": [
    "inkress",
    "storefront",
    "ecommerce",
    "sdk",
    "typescript",
    "javascript",
    "browser",
    "cart",
    "wishlist",
    "products",
    "categories",
    "reviews",
    "shipping",
    "checkout",
    "payments",
    "type-safe",
    "query-builder"
  ],
  "author": {
    "name": "Inkress",
    "email": "dev@inkress.com",
    "url": "https://inkress.com"
  },
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/inkress/storefront-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/inkress/storefront-sdk/issues"
  },
  "homepage": "https://github.com/inkress/storefront-sdk#readme",
  "dependencies": {
    "cross-fetch": "^4.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "rollup": "^4.6.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
